# Local development: point to your backend (run: cd backend && uvicorn server:app --reload)
REACT_APP_BACKEND_URL=http://127.0.0.1:8000

# Production (e.g. Vercel): set this to your deployed backend URL (no /api suffix).
# Example: https://your-app.railway.app or https://api.yourdomain.com
# Without this, the app will call same-origin /api and login/signup will not work on Vercel.
# REACT_APP_BACKEND_URL=https://your-backend.example.com

# Google Sign-In (optional). Required only if you use "Sign in with Google".
# REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
