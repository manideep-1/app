MONGO_URL="mongodb://localhost:27017"
DB_NAME="ifelse_db"
CORS_ORIGINS="*"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Optional: Email OTP for signup. If not set, OTP is logged to console (dev only).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USER=
# SMTP_PASSWORD=
# MAIL_FROM=noreply@example.com
# APP_NAME=ifelse

# Google Sign-In (optional). Get client ID from Google Cloud Console → APIs & Services → Credentials.
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# AI Coach (optional). If not set, coach endpoints return a fallback message.
# OPENAI_API_KEY=sk-...
# AI_COACH_API_KEY=...   # alternative env name for LLM API key
# AI_COACH_MODEL=gpt-4o-mini   # or gpt-4o, etc.
