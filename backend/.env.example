MONGO_URL="mongodb://localhost:27017"
DB_NAME="ifelse_db"
# Comma-separated origins (required when using credentials). Use * only without credentials.
# Example: CORS_ORIGINS="http://localhost:3000,https://yourapp.com"
# Default if unset: http://localhost:3000,http://127.0.0.1:3000
# CORS_ORIGINS=
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Optional: Email OTP for signup. If not set, OTP is logged to console (dev only).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USER=
# SMTP_PASSWORD=
# MAIL_FROM=noreply@example.com
# APP_NAME=ifelse

# Google Sign-In (optional). Get client ID from Google Cloud Console → APIs & Services → Credentials.
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# AI Coach (optional). Get an API key from https://platform.openai.com/api-keys
# If not set, the AI Coach panel shows a message and you can use built-in hints + Solution tab.
# OPENAI_API_KEY=sk-...
# AI_COACH_API_KEY=...   # alternative env name
# AI_COACH_MODEL=gpt-4o-mini   # or gpt-4o, etc.
